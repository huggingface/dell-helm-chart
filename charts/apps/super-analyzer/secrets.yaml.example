# Copy this to secrets.yaml, fill in values, and add secrets.yaml to .gitignore
# secrets.yaml is passed to helm with: -f secrets.yaml

image:
  tag: "v1.0.4"    # override image tag here if needed

secrets:
  dbPassword: "CHANGE_ME"
  adminApiKey: "CHANGE_ME"
  analyzerApiKey: "not-needed1"
  fixerApiKey: "not-needed1"
  chatApiKey: "nvapi-CHANGE_ME"    # your Nvidia API key

